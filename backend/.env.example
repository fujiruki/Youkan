# R-034 Phase 2 Google カレンダー連携用
# キー生成: php -r "echo bin2hex(random_bytes(32));"
YOUKAN_ENCRYPTION_KEY=please_replace_with_64_hex_chars

# Google Cloud Console → API & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# Authorized redirect URI を Google Cloud Console にも登録する必要あり
# 本番: https://door-fujita.com/contents/Youkan/api/google/oauth/callback
# ローカル: http://localhost:8000/api/google/oauth/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/google/oauth/callback
